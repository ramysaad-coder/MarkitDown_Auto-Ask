{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/markitdown-ask.py"],
            "timeout": 15,
            "statusMessage": "Checking if file should be converted to Markdown..."
          }
        ]
      }
    ]
  }
}
